# Copy to .env and edit. All env vars are EIGEN_-prefixed.

# --- Storage ---
# Local dev points at the Railway-hosted Postgres. Grab the public URL via:
#   railway service link Postgres && railway variables --kv | grep DATABASE_PUBLIC_URL
# Production reads DATABASE_URL injected by Railway directly into the runtime.
EIGEN_DATABASE_URL=REDACTED
EIGEN_REDIS_URL=redis://localhost:6379/0

# --- ESP ---
# log: log to stdout (dev). resend: real sends. fake: in-process test ESP.
EIGEN_ESP=log
EIGEN_RESEND_API_KEY=
EIGEN_RESEND_WEBHOOK_SECRET=
EIGEN_SENDER_FROM=Eigen <no-reply@example.com>

# --- LLM ---
EIGEN_ANTHROPIC_API_KEY=
EIGEN_LLM_MODEL=claude-sonnet-4-6
EIGEN_GENERATOR=template
EIGEN_AUTO_SPAWN=true

# --- Scheduler ---
EIGEN_SCHEDULER_ENABLED=false
EIGEN_SETTLE_WINDOW_SECONDS=86400
EIGEN_TICK_INTERVAL_SECONDS=300

# --- Stopping rule ---
EIGEN_STOP_PROB_BEST=0.95

# --- Auth ---
# Comma-separated. If empty, auth is disabled (dev only).
EIGEN_API_KEYS=
